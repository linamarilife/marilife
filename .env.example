# Database
DATABASE_URL="file:./dev.db"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HealthSherpa API (get your keys from https://developers.healthsherpa.com/)
HEALTHSHERPA_API_KEY="your_api_key_here"
HEALTHSHERPA_BASE_URL="https://api.healthsherpa.com"

# Twilio for auto follow-ups (get from https://www.twilio.com/)
TWILIO_ACCOUNT_SID="your_account_sid_here"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"

# Optional: Analytics, CRM integrations, etc.
# GOOGLE_ANALYTICS_ID=""
# SALESFORCE_CLIENT_ID=""
# HUBSPOT_API_KEY=""